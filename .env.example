# Credenciais do Cloudflare R2 — NUNCA commitar o arquivo .env real (só este .example).
# Copie este arquivo para .env e preencha com os valores reais do seu R2 API Token.
#
# Onde encontrar:
#   - R2_ACCOUNT_ID: painel R2 > canto superior direito, ou na URL do dashboard
#     (https://dash.cloudflare.com/<ACCOUNT_ID>/r2)
#   - R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY: gerados na criação do Account API Token
#     (mostrados uma única vez — se perdeu, precisa gerar um token novo)

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Nomes dos buckets (já criados no painel R2)
R2_BUCKET_BRONZE=access-intelligence-bronze
R2_BUCKET_SILVER=access-intelligence-silver
R2_BUCKET_GOLD=access-intelligence-gold
R2_BUCKET_CACHE=access-intelligence-cache
